pipeline {
    agent any

    tools {
        maven 'maven3'
        jdk 'openjdk17'
    }

    environment {
        SONAR_SCANNER_HOME = tool 'sonar-scanner'
        DOCKER_IMAGE = 'relaxamj/santa-project:santa-latest'
    }

    stages {

        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/relaxamj/petclinic.git'
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Build Maven Package') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh """
                        ${SONAR_SCANNER_HOME}/bin/sonar-scanner \
                        -Dsonar.projectKey=petclinic \
                        -Dsonar.sources=src \
                        -Dsonar.java.binaries=target/classes
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -t ${DOCKER_IMAGE} ."
            }
        }

        stage('Docker Push') {
            steps {
                withDockerRegistry(
                    credentialsId: 'Dockerhub',
                    url: 'https://index.docker.io/v1/'
                ) {
                    sh "docker push ${DOCKER_IMAGE}"
                }
            }
        }

        stage('Deploy Stage 2') {
            steps {
                sh """

            # Run new container
            docker run -d \
                --name santa-app \
                -p 8082:8082 \
                ${DOCKER_IMAGE}
        """
            }
        }
    }
}
